<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device Specifications"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device Model:"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/device_model"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SoC Model:"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/soc_model"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CPU Architecture:"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/cpu_architecture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CPU Cores:"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/cpu_cores"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CPU Core Frequencies:"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/cpu_frequency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GPU Vendor:"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/gpu_vendor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GPU Renderer:"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/gpu_renderer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RAM:"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/ram_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Storage:"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/storage_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Display Resolution:"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/display_resolution"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Android Version:"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/android_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
    </ScrollView>
    <android.opengl.GLSurfaceView
        android:id="@+id/gl_surface_view"
        android:layout_width="1px"
        android:layout_height="1px"
        android:visibility="gone" />
</FrameLayout>