<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Select Benchmark Tests"
            android:textSize="20sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/checkbox_select_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select All"
            android:textSize="16sp" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/checkbox_cpu_single"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CPU Benchmark Single-Core"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <CheckBox
        android:id="@+id/checkbox_cpu_multi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CPU Benchmark Multi-Core"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <CheckBox
        android:id="@+id/checkbox_gpu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GPU Benchmark"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <CheckBox
        android:id="@+id/checkbox_memory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Memory Benchmark"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

    <CheckBox
        android:id="@+id/checkbox_storage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Storage Benchmark"
        android:textSize="16sp"
        android:layout_marginBottom="20dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/button_show_prev_tests"
            style="@style/Widget.AppCompat.Button.Colored"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:enabled="false"
            android:text="Previous Tests"
            android:textAlignment="center"
            android:textAllCaps="false"
            android:textSize="18sp" />

        <Button
            android:id="@+id/button_start_test"
            style="@style/Widget.AppCompat.Button.Colored"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:enabled="false"
            android:text="Start Tests"
            android:textAllCaps="false"
            android:textSize="18sp" />

        <Button
            android:id="@+id/button_graphs"
            style="@style/Widget.AppCompat.Button.Colored"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:enabled="false"
            android:text="Show Graphs"
            android:textAllCaps="false"
            android:textSize="18sp" />
    </LinearLayout>

</LinearLayout>